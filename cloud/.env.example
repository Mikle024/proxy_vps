# Public host/IP used in generated tg:// links.
PUBLIC_HOST=<YOUR_PUBLIC_HOST_OR_IP>

# TLS masking domain.
TLS_DOMAIN=<YOUR_TLS_DOMAIN>

# User secrets (32 hex symbols).
# openssl rand -hex 16
TELEMT_USER_MY_SECRET=PUT_32_HEX_SECRET_FOR_MY=<SECRET>

# Per-user unique IP limit.
TELEMT_USER_TIGI_MAX_UNIQUE_IPS=<COUNT>

# Local upstream SOCKS5 endpoint.
UPSTREAM_ADDR=<IP:PORT>